.shipstudio/
Thumbs.db
node_modules/
dist/
# Browser-ready AVIF/WebP files are the canonical deployable image assets.
# Heavy originals and intermediate normalized files stay local only.
assets/source/*.jpg
assets/source/*.jpeg
assets/source/*.png
assets/normalized/*
!assets/normalized/.gitkeep

# Heavy raw video sources stay local only — encoded web versions live in assets/static/
assets/source/*.mov
assets/source/*.mp4
assets/source/*.m4v
assets/source/*.avi
assets/source/*.mkv
.wrangler/
.vercel/
.dev.vars
.env
.vercel
