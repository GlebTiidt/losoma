Options -Indexes -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteRule ^ https://losoma.de%{REQUEST_URI} [R=301,L]

  RewriteCond %{HTTP_HOST} ^www\.losoma\.de$ [NC]
  RewriteRule ^ https://losoma.de%{REQUEST_URI} [R=301,L]

  RewriteRule ^api/contact/?$ api/contact.php [L,QSA]
  RewriteRule ^api/health/?$ api/health.php [L,QSA]

  RewriteCond %{THE_REQUEST} \s/+blog/+[?\s] [NC]
  RewriteRule ^blog/$ /blog [R=301,L]

  RewriteRule ^blog$ blog/index.html [L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set X-Frame-Options "DENY"

  <FilesMatch "\.(?:avif|webp|png|jpg|jpeg|svg|woff2|mp4)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:html|css|js)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  <FilesMatch "^(?:contact|health)\.php$">
    Header set Cache-Control "no-store"
  </FilesMatch>
</IfModule>

<FilesMatch "^(?:\.env|contact-config\.php|composer\.(?:json|lock))$">
  Require all denied
</FilesMatch>
