# Contact form delivery
# Required before the form can send real notifications.
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_SECRET=
CONTACT_TO_EMAIL=maxim@losoma.de

# Basic server-side throttling for /api/contact.
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600

# Planned next stage. Do not enable these without matching server-side verification
# and a synchronized update to datenschutz.html.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_EXPECTED_ACTION=contact
